{
  "$schema": "http://json-schema.org/draft-07/schema",
  "additionalProperties": false,
  "properties": {
    "members": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "email": {
            "type": "string"
          },
          "id": {
            "type": "integer"
          },
          "jtime": {
            "format": "datetime",
            "type": "string"
          }
        },
        "required": [
          "email",
          "id",
          "jtime"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "organization": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "type": "object"
    },
    "team": {
      "additionalProperties": false,
      "properties": {
        "ctime": {
          "format": "datetime",
          "type": "string"
        },
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "ctime",
        "id",
        "name"
      ],
      "type": "object"
    }
  },
  "required": [
    "members",
    "organization",
    "team"
  ],
  "type": "object"
}