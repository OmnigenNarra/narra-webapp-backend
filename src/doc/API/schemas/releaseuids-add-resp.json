{
  "$schema": "http://json-schema.org/draft-07/schema",
  "additionalProperties": false,
  "properties": {
    "ctime": {
      "format": "datetime",
      "type": "string"
    },
    "id": {
      "type": "integer"
    },
    "organization": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "type": "object"
    },
    "release": {
      "additionalProperties": false,
      "properties": {
        "changes": {
          "type": "string"
        },
        "id": {
          "type": "integer"
        },
        "release_ver": {
          "type": "string"
        },
        "unreal_ver": {
          "type": "string"
        }
      },
      "required": [
        "changes",
        "id",
        "release_ver",
        "unreal_ver"
      ],
      "type": "object"
    },
    "uid": {
      "type": "string"
    },
    "url": {
      "type": "string"
    }
  },
  "required": [
    "ctime",
    "id",
    "organization",
    "release",
    "uid",
    "url"
  ],
  "type": "object"
}