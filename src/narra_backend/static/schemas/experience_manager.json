{
  "$schema": "http://json-schema.org/draft-07/schema",
  "additionalProperties": false,
  "definitions": {
    "nameCountEntry": {
      "additionalProperties": false,
      "properties": {
        "Count": {
          "type": "integer"
        },
        "Name": {
          "type": "string"
        }
      },
      "required": [
        "Count",
        "Name"
      ],
      "type": "object"
    },
    "storyEntry": {
      "additionalProperties": false,
      "properties": {
        "EntityCount": {
          "type": "integer"
        },
        "EntityTypes": {
          "items": {
            "$ref": "#/definitions/nameCountEntry"
          },
          "type": "array"
        },
        "MaxPath": {
          "type": "integer"
        },
        "MinPath": {
          "type": "integer"
        },
        "NodeCount": {
          "type": "integer"
        },
        "NodeTypes": {
          "items": {
            "$ref": "#/definitions/nameCountEntry"
          },
          "type": "array"
        },
        "StoryName": {
          "type": "string"
        },
        "StoryWeight": {
          "type": "integer"
        }
      },
      "required": [
        "EntityCount",
        "EntityTypes",
        "MaxPath",
        "MinPath",
        "NodeCount",
        "NodeTypes",
        "StoryName",
        "StoryWeight"
      ],
      "type": "object"
    }
  },
  "properties": {
    "Stories": {
      "items": {
        "$ref": "#/definitions/storyEntry"
      },
      "type": "array"
    },
    "StoriesCount": {
      "items": {
        "$ref": "#/definitions/nameCountEntry"
      },
      "type": "array"
    }
  },
  "required": [
    "Stories",
    "StoriesCount"
  ],
  "type": "object"
}